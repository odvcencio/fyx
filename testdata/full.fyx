script Weapon {
    inspect damage: f32 = 25.0
    inspect fire_rate: f32 = 0.1

    node muzzle: Node = "MuzzlePoint"
    node flash: Light = "MuzzleFlash"
    resource fire_sound: SoundBuffer = "res://audio/rifle_fire.wav"
    resource projectile_prefab: Model = "res://models/projectile.rgs"

    reactive ammo: i32 = 30
    derived can_fire: bool = self.ammo > 0
    derived ammo_display: String = format!("{} / 30", self.ammo)

    signal fired(position: Vector3, direction: Vector3)
    signal emptied()

    timer fire_cooldown = self.fire_rate

    state armed {
        on update {
            self.flash.set_visibility(true);
            if self.ammo <= 0 {
                go empty;
            }
            if self.ammo > 0 && fire_cooldown.ready {
                let muzzle = self.muzzle;
                let origin = muzzle.position();
                let direction = muzzle.forward();
                let projectile_prefab = self.projectile_prefab;
                let projectile = spawn projectile_prefab at origin lifetime 1.0;
                let projectile_origin = projectile.position();
                let _shot = ecs.spawn(
                    Projectile { damage: self.damage, owner: projectile },
                    Velocity { linear: direction * 24.0, angular: Vector3::default() },
                ) lifetime 1.0;
                emit fired(projectile_origin, direction);
                self.flash.set_visibility(true);
                fire_cooldown.reset();
                self.ammo -= 1;
                if self.ammo <= 0 {
                    go empty;
                }
            }
        }
    }

    state empty {
        on enter {
            emit emptied();
        }

        on update {
            self.flash.set_visibility(false);
        }
    }
}

script WeaponHUD {
    node ammo_label: Text = "UI/AmmoCount"
    node crosshair: Sprite = "UI/Crosshair"
    nodes ammo_digits: Text = "UI/AmmoDigits/*"

    connect Weapon::fired(pos, dir) {
        self.crosshair.animate("kick");
        if let Some(weapon) = self.parent().script::<Weapon>() {
            let ammo_text = weapon.ammo_display.clone();
            self.ammo_label.set_text(ammo_text.clone());
            let crosshair = self.crosshair;
            let reticle_ring = scene.find::<Sprite>("UI/Crosshair/Reticle/Ring");
            reticle_ring.set_visibility(true);
            for reticle_part in crosshair.children() {
                reticle_part.set_visibility(true);
            }
            scene.find_all::<Sprite>("UI/Crosshair/Reticle/Marks/*").set_visibility(true);
            self.ammo_digits.set_text(ammo_text.clone());
        }
    }
}

script Damageable {
    signal damaged(amount: f32, source: Handle<Node>)
}

component Projectile {
    damage: f32
    owner: Handle<Node>
}

component Velocity {
    linear: Vector3
    angular: Vector3
}

system move_projectiles(dt: f32) {
    query(pos: &mut Transform, vel: &Velocity) {
        pos.translate(vel.linear * dt);
    }
}

system projectile_hits {
    query(entity: Entity, pos: &Transform, vel: &Velocity, proj: &Projectile) {
        let owner = proj.owner;
        let owner_origin = owner.position();
        let _ = owner_origin;
        for hit in scene.physics.raycast(pos.position(), vel.linear.normalized(), 0.5) {
            emit Damageable::damaged(amount: proj.damage, source: owner) to hit.node;
            despawn(entity);
        }
    }
}
